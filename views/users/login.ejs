<% layout('layouts/boilerplate') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5 col-md-7">

      <div class="card shadow-sm border-0 p-4" style="border-radius: 12px;">

        <h3 class="text-center mb-4 fw-bold" style="color:#0A2342;">
          Welcome Back
        </h3>

        <form action="/login" method="POST" autocomplete="off">

          <!-- Username -->
          <div class="mb-3">
            <label class="form-label fw-semibold" style="color:#0A2342;">Username</label>
            <input 
              type="text" 
              name="username" 
              class="form-control form-control-lg"
              placeholder="Enter your username"
              required
            >
          </div>

          <!-- Password -->
          <div class="mb-3">
            <label class="form-label fw-semibold" style="color:#0A2342;">Password</label>
            <input 
              type="password" 
              name="password" 
              class="form-control form-control-lg"
              placeholder="Enter password"
              required
            >
          </div>

          <button 
            class="btn btn-lg w-100 mt-3 shadow-sm"
            style="background:#0A2342;color:white;"
          >
            Login
          </button>

        </form>

        <p class="text-center mt-3">
          Don't have an account?
          <a href="/signup" class="text-decoration-none fw-semibold" style="color:#0A2342;">
            Sign Up
          </a>
        </p>

      </div>

    </div>
  </div>
</div>
