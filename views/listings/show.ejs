<% layout('layouts/boilerplate') %>
<script>
  const maptoken = "<%= process.env.MAP_TOKEN %>"
  const coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;
</script>
<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">

      <div class="card stayo-detail-card">

        <!-- Image -->
        <img 
          src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1505691938895-1758d7feb511' %>" 
          class="card-img-top stayo-detail-img" 
          alt="<%= listing.title %>"
        >

        <div class="card-body">

          <!-- Title -->
          <h2 class="card-title mb-2"><%= listing.title %></h2>

          <!-- Location -->
          <p class="text-muted mb-3">
            <i class="fa-solid fa-location-dot me-1"></i>
            <%= listing.location %>, <%= listing.country %>
          </p>

          <!-- Owner -->
        <p class="text-muted mb-3">
          Owned by 
          <strong><%= listing.owner?.username || "Unknown" %></strong>
        </p>

          <!-- Description -->
          <p class="card-text mb-4">
            <%= listing.description %>
          </p>

          <!-- Price -->
          <h4 class="price mb-4">
            ₹ <%= listing.price.toLocaleString('en-IN') %>
            <span class="text-muted fs-6"> / night</span>
          </h4>

          <!-- Actions -->
          <% if (currentUser && listing.owner && listing.owner.equals(currentUser._id)) { %>
            <div class="d-flex gap-2">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-stayo">
                Edit
              </a>

              <form 
                method="POST" 
                action="/listings/<%= listing._id %>?_method=DELETE"
              >
                <button class="btn btn-outline-danger" type="submit">
                  Delete
                </button>
              </form>
            </div>
          <% } %>

          <hr>
                 
          <!-- Review Form -->
          <% if (currentUser) { %>
            <div class="mt-5 text-start">
              <h3 class="mb-3">Write a Review</h3>

              <form 
                action="/listings/<%= listing._id %>/reviews" 
                method="POST" 
                novalidate 
                class="needs-validation"
              >

                <!-- Rating -->
                <div class="mb-3">
                  <label class="form-label fw-semibold text-start d-block">
                    Rating
                  </label>

                  <fieldset 
                    class="starability-basic text-start" 
                    style="transform: scale(1.15);"
                  >
                    <legend class="visually-hidden">Rating</legend>

                    <input type="radio" id="rate1" name="review[rating]" value="1" />
                    <label for="rate1" title="1 star">1 star</label>

                    <input type="radio" id="rate2" name="review[rating]" value="2" />
                    <label for="rate2" title="2 stars">2 stars</label>

                    <input type="radio" id="rate3" name="review[rating]" value="3" />
                    <label for="rate3" title="3 stars">3 stars</label>

                    <input type="radio" id="rate4" name="review[rating]" value="4" />
                    <label for="rate4" title="4 stars">4 stars</label>

                    <input type="radio" id="rate5" name="review[rating]" value="5" required />
                    <label for="rate5" title="5 stars">5 stars</label>

                    <span class="starability-focus-ring"></span>
                  </fieldset>
                </div>

                <!-- Comment -->
                <div class="mb-3">
                  <label class="form-label fw-semibold text-start d-block">
                    Comment
                  </label>

                  <textarea 
                    name="review[comment]" 
                    class="form-control" 
                    rows="4" 
                    placeholder="Share your experience..." 
                    required
                  ></textarea>

                  <div class="invalid-feedback">
                    Please enter your comment.
                  </div>
                </div>

                <!-- Submit -->
              <div class="text-start">
              <button class="btn btn-success px-4" type="submit">
                Submit Review
              </button>
            </div>


              </form>
            </div>
          <% } %>

          <hr>

      <h4 class="mt-4">All Reviews</h4>

        <% if (listing.reviews.length === 0) { %>
          <p class="text-muted">No reviews yet.</p>
        <% } %>

        <div class="row mt-3">
          <% listing.reviews.forEach(review => { %>
            <div class="col-md-6 mb-4">
              <div 
                class="card h-100"
                style="
                  border-radius:16px;
                  border:1px solid #eaeaea;
                  transition: all 0.25s ease;
                "
              >
                <div class="card-body text-start d-flex flex-column">

                  <!-- Header -->
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <h6 class="fw-semibold mb-0">
                      @<%= review.author?.username || "Anonymous" %>
                    </h6>

                    <small class="text-muted">
                      <%= review.createdAt.toLocaleDateString('en-IN') %>
                    </small>
                  </div>

                  <!-- Rating -->
                  <div 
                    class="starability-result mb-2"
                    data-rating="<%= review.rating %>"
                    style="transform: scale(0.9);">
                  </div>

                  <!-- Comment -->
                  <p class="text-muted mb-3" style="font-size:0.95rem; line-height:1.5;">
                    <%= review.comment %>
                  </p>

                  <!-- Action -->
                  <% if (currentUser && review.author && review.author.equals(currentUser._id)) { %>
                    <div class="mt-auto">
                      <form 
                        method="POST" 
                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                      >
                        <button class="btn btn-outline-danger btn-sm">
                          Delete
                        </button>
                      </form>
                    </div>
                  <% } %>

                </div>
              </div>
            </div>
          <% }) %>
        </div>
        <div>
          <h3>where you'll be</h3>
          <div id="map"></div>
        
        </div>

        </div>

      </div>

    </div>
  </div>
</div>
<script src="/js/map.js"></script>
